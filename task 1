import java.util.ArrayList;
import java.util.Scanner;

// 1. MAIN CLASS AT THE TOP (Contains the entry point)
public class GradeTracker {
    public static void main(String[] args) {
        ArrayList<Student> studentList = new ArrayList<>();
        Scanner scanner = new Scanner(System.in);
        
        System.out.println("=== Student Grade Tracker ===");
        
        while (true) {
            System.out.print("\nEnter student name (or type 'exit' to finish): ");
            String name = scanner.nextLine().trim();
            
            if (name.equalsIgnoreCase("exit")) {
                break;
            }
            
            if (name.isEmpty()) {
                System.out.println("Name cannot be empty. Please try again.");
                continue;
            }

            double grade = -1;
            while (true) {
                System.out.print("Enter grade for " + name + " (0 - 100): ");
                if (scanner.hasNextDouble()) {
                    grade = scanner.nextDouble();
                    if (grade >= 0 && grade <= 100) {
                        break;
                    } else {
                        System.out.println("Invalid input. Grade must be between 0 and 100.");
                    }
                } else {
                    System.out.println("Invalid input. Please enter a valid number.");
                    scanner.next(); // Clear invalid token
                }
            }
            scanner.nextLine(); // Consume remaining newline

            // Add new student to the ArrayList
            studentList.add(new Student(name, grade));
        }

        // Check if any data was entered
        if (studentList.isEmpty()) {
            System.out.println("\nNo student data entered. Exiting program.");
        } else {
            displaySummaryReport(studentList);
        }
        
        scanner.close();
    }

    /**
     * Method to calculate statistics and display the final report.
     */
    private static void displaySummaryReport(ArrayList<Student> students) {
        double total = 0;
        double highest = students.get(0).getGrade();
        double lowest = students.get(0).getGrade();
        
        String highestStudent = students.get(0).getName();
        String lowestStudent = students.get(0).getName();

        System.out.println("\n=================================");
        System.out.println("         SUMMARY REPORT          ");
        System.out.println("=================================");
        System.out.printf("%-20s %-10s\n", "Student Name", "Grade");
        System.out.println("---------------------------------");

        for (Student s : students) {
            double currentGrade = s.getGrade();
            total += currentGrade;

            // Print individual student row
            System.out.printf("%-20s %-10.2f\n", s.getName(), currentGrade);

            // Track highest score
            if (currentGrade > highest) {
                highest = currentGrade;
                highestStudent = s.getName();
            }

            // Track lowest score
            if (currentGrade < lowest) {
                lowest = currentGrade;
                lowestStudent = s.getName();
            }
        }

        double average = total / students.size();

        // Display Calculated Statistics
        System.out.println("---------------------------------");
        System.out.printf("Total Students : %d\n", students.size());
        System.out.printf("Average Grade  : %.2f\n", average);
        System.out.printf("Highest Grade  : %.2f (%s)\n", highest, highestStudent);
        System.out.printf("Lowest Grade   : %.2f (%s)\n", lowest, lowestStudent);
        System.out.println("=================================");
    }
}

// 2. HELPER CLASS AT THE BOTTOM
class Student {
    private String name;
    private double grade;

    public Student(String name, double grade) {
        this.name = name;
        this.grade = grade;
    }

    public String getName() {
        return name;
    }

    public double getGrade() {
        return grade;
    }
}
